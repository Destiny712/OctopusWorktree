# =============================
#  Octopus Project .gitignore
#  (WSL + ULITE + Singularity)
# =============================

# --- 1. Sandboxes & Containers ---
sandboxes/
container/*.sif
container/*.def
container/*.img
container/*.simg
container/*.squashfs
singularity/deb/*.deb
src/

# --- 2. Data & Results ---
data/
results/
downloads/
tmp/
logs/
*.log

# --- 3. Build artifacts ---
build/
build*/        # e.g., build, build-debug, build-release
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# --- 4. Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- 5. Editor / OS junk ---
*.swp
*.swo
*.tmp
*.bak
*.DS_Store

# --- 6. Octopus-specific runtime outputs ---
*.root
*.bin
*.dat
*.npy
*.npz
*.h5
*.so
*.o
*.a

# --- 7. WSL / ULITE environment noise ---
*.pid
nohup.out

# --- 8. VSCode / JetBrains ---
.vscode/
.idea/

# --- 9. Credentials (just in case) ---
*.key
*.pem
*.crt

# --- 10. Keep config directory tracked ---
!config/
